#!/bin/sh
# pre-commit: Prettier 포맷 검사 — 위반 시 커밋 차단

# 스테이지된 .ts/.tsx 파일만 검사 (git root 기준 경로 그대로 사용)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

echo "🔍 Prettier 포맷 검사 중..."

# prettier는 git root에서 실행 (my-insta-dm/.prettierrc 자동 탐색)
cd my-insta-dm && npx prettier --check $(echo "$STAGED" | sed 's|^my-insta-dm/||')

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ 포맷 오류가 있습니다. 아래 명령어로 수정 후 다시 커밋하세요:"
  echo "   cd my-insta-dm && npx prettier --write ."
  exit 1
fi

echo "✅ 포맷 검사 통과"
